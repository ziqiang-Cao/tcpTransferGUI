    </mxGraphModel>
  </diagram>
  <diagram id="locks-page" name="05-锁说明">
    <mxGraphModel dx="1600" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="2200" pageHeight="1400" math="0" shadow="0">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>
        <mxCell id="2" value="锁与并发模型说明（适合汇报页）" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#12344d;fontColor=#ffffff;strokeColor=#12344d;fontSize=22;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="610" y="20" width="980" height="70" as="geometry"/>
        </mxCell>

        <mxCell id="10" value="客户端锁" style="swimlane;rounded=1;whiteSpace=wrap;html=1;fillColor=#edf7f4;strokeColor=#1c7f78;fontStyle=1;fontSize=18;horizontal=1;startSize=34;" vertex="1" parent="1">
          <mxGeometry x="40" y="130" width="1000" height="960" as="geometry"/>
        </mxCell>
        <mxCell id="11" value="ClientStateStore._lock&#xa;类型：threading.RLock&#xa;保护对象：_state / state.json&#xa;场景：load_settings/save_settings/load_tasks/save_tasks/...&#xa;原因：UI 线程与任务回调可能并发写状态；save_settings() 内部还会再次读取设置，因此用 RLock。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1c7f78;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="10">
          <mxGeometry x="30" y="60" width="930" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="12" value="TransferTask._progress_lock&#xa;类型：threading.Lock&#xa;保护对象：completed_bytes / _last_emit / 速度统计&#xa;场景：多个分片线程同时上报 _report_progress()&#xa;原因：ThreadPoolExecutor 并发上传 / 下载分片时，若不加锁，进度和速度会出现重复累计、乱序跳变。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#1c7f78;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="10">
          <mxGeometry x="30" y="285" width="930" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="13" value="TransferTask._stop_requested&#xa;类型：threading.Event（不是锁）&#xa;作用：暂停 / 停止的跨线程中断协作&#xa;场景：pause()/stop() 设置标记，工作线程在 _check_interrupted() 检测后抛出 __paused__ 或 __stopped__。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dff1ee;strokeColor=#1c7f78;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="10">
          <mxGeometry x="30" y="510" width="930" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="14" value="客户端没有显式 UI 锁&#xa;原因：Qt Widget 只能在 GUI 主线程更新；后台任务通过 pyqtSignal 回到主线程，因此不对 MainWindow 控件本身加锁。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef5ff;strokeColor=#5b6dd1;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="10">
          <mxGeometry x="30" y="705" width="930" height="120" as="geometry"/>
        </mxCell>

        <mxCell id="30" value="服务端锁" style="swimlane;rounded=1;whiteSpace=wrap;html=1;fillColor=#fff3e7;strokeColor=#d87733;fontStyle=1;fontSize=18;horizontal=1;startSize=34;" vertex="1" parent="1">
          <mxGeometry x="1100" y="130" width="1060" height="960" as="geometry"/>
        </mxCell>
        <mxCell id="31" value="TransferServer._state_lock&#xa;类型：threading.RLock&#xa;保护对象：_running / _server_socket / _sessions / _stats&#xa;场景：start/stop/is_running/current_stats/_handle_login/_require_session/_bump_stat/_emit_sessions/update_user/purge_expired_users&#xa;原因：服务端同时存在 GUI 线程、accept 线程、maintenance 线程、多个 handler 线程，共享运行态必须统一保护。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d87733;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="30">
          <mxGeometry x="30" y="60" width="990" height="200" as="geometry"/>
        </mxCell>
        <mxCell id="32" value="UserStore.lock&#xa;类型：threading.RLock&#xa;保护对象：_data[&quot;users&quot;] / users.json&#xa;场景：登录校验、管理员增删改、到期清理、默认管理员初始化&#xa;原因：管理员操作、登录线程、维护线程可能同时触碰用户数据。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d87733;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="30">
          <mxGeometry x="30" y="300" width="990" height="160" as="geometry"/>
        </mxCell>
        <mxCell id="33" value="ServerSettingsStore._lock&#xa;类型：threading.RLock&#xa;保护对象：_settings / settings.json&#xa;场景：GUI 连续修改 host / port / auto_start 时&#xa;原因：避免多个界面信号短时间连续触发导致配置写坏或互相覆盖。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d87733;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="30">
          <mxGeometry x="30" y="500" width="990" height="150" as="geometry"/>
        </mxCell>
        <mxCell id="34" value="FileStorage._locks[username:upload_id]&#xa;类型：threading.Lock（按上传会话分桶）&#xa;保护对象：同一 upload_id 的“检查是否齐片 + 合并分片”关键区&#xa;场景：write_upload_chunk()&#xa;原因：多个分片线程可能几乎同时完成最后几片，没有这把锁会触发重复合并、文件竞争覆盖。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d87733;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="30">
          <mxGeometry x="30" y="690" width="990" height="170" as="geometry"/>
        </mxCell>

        <mxCell id="40" value="并发边界总结" style="swimlane;rounded=1;whiteSpace=wrap;html=1;fillColor=#eef2fb;strokeColor=#5b6dd1;fontStyle=1;fontSize=18;horizontal=1;startSize=34;" vertex="1" parent="1">
          <mxGeometry x="320" y="1130" width="1560" height="180" as="geometry"/>
        </mxCell>
        <mxCell id="41" value="客户端：MainWindow 在 GUI 主线程；每个 TransferTask 是一个 QThread；每个 TransferTask 内又通过 ThreadPoolExecutor 并发多个分片。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5b6dd1;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="40">
          <mxGeometry x="30" y="60" width="1480" height="42" as="geometry"/>
        </mxCell>
        <mxCell id="42" value="服务端：一个 accept_thread + 一个 maintenance_thread + 多个 handler 线程；凡是共享运行态都通过 _state_lock / UserStore.lock / FileStorage 会话锁协同。" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#5b6dd1;fontSize=15;align=left;spacingLeft=12;" vertex="1" parent="40">
          <mxGeometry x="30" y="112" width="1480" height="42" as="geometry"/>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
