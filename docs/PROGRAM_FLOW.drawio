        <mxCell id="16" value="run_headless()&#xa;QCoreApplication&#xa;server.start(host, port)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d87733;fontSize=16;" vertex="1" parent="10"><mxGeometry x="90" y="665" width="250" height="90" as="geometry"/></mxCell>
